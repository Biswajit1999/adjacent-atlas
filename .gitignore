# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
out/
*.tsbuildinfo

# Test output
coverage/

# Turbo
.turbo/

# Generated data artifacts (kept out of VCS by default; commit deliberately)
data/snapshots/*.json
data/briefs/*.json
!data/snapshots/.gitkeep
!data/briefs/.gitkeep
# Ingestion pipeline outputs (generated)
data/raw/*
!data/raw/.gitkeep
data/cache/*
!data/cache/.gitkeep


# Environment
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.log
