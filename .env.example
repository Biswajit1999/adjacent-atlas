# Adjacent Atlas — environment variables
#
# Copy this file to `.env.local` (for the web app, under apps/web) or `.env`
# (for scripts, at the repo root) and fill in values. All variables here are
# optional; sensible defaults are used when they are unset.

# Public base URL of the deployed site, with no trailing slash.
# Used by app/robots.ts, app/sitemap.ts, and the Open Graph metadata.
# Set this to your real domain before deploying.
NEXT_PUBLIC_SITE_URL=https://adjacent-atlas.dev

# --- Ingestion pipeline (all optional) ---
# A GitHub token raises the Search API rate limit. A fine-grained token with
# no extra scopes (public read) is sufficient. Leave unset to use the lower
# unauthenticated limit.
# GITHUB_TOKEN=

# Contact email to join OpenAlex's faster "polite pool". Optional.
# OPENALEX_MAILTO=
